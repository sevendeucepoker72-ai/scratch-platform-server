{
  "name": "scratch-platform-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node ./node_modules/prisma/build/index.js generate",
    "start": "node ./node_modules/prisma/build/index.js db push --skip-generate && node --import tsx src/index.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "seed:admin": "tsx src/seed-admin.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "@sendgrid/mail": "^8.1.0",
    "better-auth": "^1.2.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "pdfkit": "^0.18.0",
    "prisma": "^6.0.0",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.0",
    "stripe": "^14.21.0",
    "tsx": "^4.7.0",
    "twilio": "^5.13.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.17.5",
    "@types/qrcode": "^1.5.6",
    "typescript": "^5.6.0"
  }
}
