generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Better Auth tables ──────────────────────────────────────
// These are managed by Better Auth's Prisma adapter.

model user {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      session[]
  accounts      account[]
}

model session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model account {
  id                String  @id @default(cuid())
  userId            String
  accountId         String
  providerId        String
  accessToken       String?
  refreshToken      String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope             String?
  idToken           String?
  password          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              user     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ── Application tables ──────────────────────────────────────

model AppUser {
  id          String   @id @default(cuid())
  authId      String   @unique // links to user.id (Better Auth)
  email       String   @unique
  displayName String
  role        String   @default("player") // player, staff, admin, finance, super_admin
  venueIds    String   @default("[]")
  isActive    Boolean  @default(true)
  orgId       String?
  orgRole     String?
  orgName     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastLoginAt DateTime?

  tickets     Ticket[]
  claims      Claim[]
  auditLogs   AuditLog[]   @relation("AuditActor")

  @@map("app_users")
}

model Organization {
  id                     String   @id @default(cuid())
  name                   String
  slug                   String   @unique
  ownerId                String   // AppUser.id
  logoUrl                String?
  primaryColor           String?
  isActive               Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  // Subscription
  subscriptionTier       String   @default("starter")
  subscriptionStatus     String   @default("active")
  stripeCustomerId       String?
  stripeSubscriptionId   String?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?

  // Usage
  ticketsIssuedThisMonth Int      @default(0)
  ticketsResetAt         DateTime?
  overageTickets         Int      @default(0)
  overageAmountCents     Int      @default(0)

  members     OrgMember[]
  invites     OrgInvite[]
  campaigns   Campaign[]
  venues      Venue[]      @relation("OrgVenues")
  apiKeys     ApiKey[]
  webhookEndpoints WebhookEndpoint[]
  referralCodes    ReferralCode[]

  @@map("organizations")
}

model OrgMember {
  id          String   @id @default(cuid())
  orgId       String
  userId      String
  email       String
  displayName String
  role        String   @default("staff") // owner, admin, staff, viewer
  joinedAt    DateTime @default(now())
  invitedBy   String?

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@map("org_members")
}

model OrgInvite {
  id          String   @id @default(cuid())
  orgId       String
  orgName     String
  inviteeEmail String
  role        String   @default("staff")
  token       String   @unique @default(cuid())
  invitedBy   String
  createdAt   DateTime @default(now())
  expiresAt   DateTime
  acceptedAt  DateTime?
  acceptedBy  String?
  status      String   @default("pending") // pending, accepted, expired, revoked

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("org_invites")
}

model Onboarding {
  id             String   @id // orgId
  completedSteps String   @default("[]")
  currentStep    String   @default("org_created")
  completedAt    DateTime?

  @@map("onboarding")
}

model Venue {
  id        String   @id @default(cuid())
  orgId     String?
  name      String
  address   String   @default("")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  org       Organization? @relation("OrgVenues", fields: [orgId], references: [id])
  tickets   Ticket[]
  campaigns Campaign[]

  @@map("venues")
}

model Campaign {
  id               String    @id @default(cuid())
  orgId            String?
  venueId          String
  name             String
  description      String?
  oddsProfileId    String
  gameType         String    @default("poker")
  isActive         Boolean   @default(true)
  ticketPrice      Int       @default(0)
  startDate        DateTime?
  endDate          DateTime?
  guidelines       String?
  guidelinesRequired Boolean @default(false)
  allowAnonymous   Boolean   @default(false)
  totalTicketsLimit Int?
  createdAt        DateTime  @default(now())
  createdBy        String

  org          Organization? @relation(fields: [orgId], references: [id])
  venue        Venue         @relation(fields: [venueId], references: [id])
  oddsProfile  OddsProfile   @relation(fields: [oddsProfileId], references: [id])
  tickets      Ticket[]

  @@map("campaigns")
}

model OddsProfile {
  id           String   @id @default(cuid())
  orgId        String?
  name         String
  prizes       String   @default("[]") // Array of { handRank/tierName, prizeLabel, prizeAmount, isEnabled } (JSON)
  scratchLimit Int      @default(7)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  campaigns    Campaign[]

  @@map("odds_profiles")
}

model Ticket {
  id              String   @id @default(cuid())
  playerId        String?
  venueId         String
  campaignId      String
  orgId           String?
  deck            String   @default("[]") // string[] — shuffled card/item IDs (JSON)
  revealedCardIds String   @default("[]") // string[]
  scratchLimit    Int      @default(7)
  gameType        String   @default("poker")
  status          String   @default("issued")
  isFrozen        Boolean  @default(false)
  freezeReason    String?
  frozenAt        DateTime?
  frozenBy        String?
  claimCodeHash   String?
  claimCodeEmailSentAt DateTime?
  prizeSnapshot   String?  // PrizeSnapshot (JSON string)
  bestHandAtScratch Json?  // PrizeSnapshot
  allowAnonymous  Boolean  @default(false)
  distributionBatch Boolean @default(false)
  issuedBy        String?
  anonymousPlayer String?  // { email, name, phone } (JSON string)

  payoutOverride      Int?
  payoutOverrideNote  String?
  payoutOverrideBy    String?
  payoutOverrideRole  String?
  payoutOverrideAt    DateTime?

  createdAt       DateTime @default(now())
  finalizedAt     DateTime?
  claimSubmittedAt DateTime?
  approvedAt      DateTime?
  redeemedAt      DateTime?

  player   AppUser? @relation(fields: [playerId], references: [id])
  venue    Venue    @relation(fields: [venueId], references: [id])
  campaign Campaign @relation(fields: [campaignId], references: [id])
  claim    Claim?
  riskScore RiskScore?
  fraudEvents FraudEvent[]

  @@index([playerId, status])
  @@index([campaignId])
  @@index([venueId, status])
  @@map("tickets")
}

model Claim {
  id            String   @id // same as ticketId for deterministic dedup
  ticketId      String   @unique
  playerId      String?
  venueId       String
  campaignId    String
  orgId         String?
  prizeSnapshot String   @default("{}") // PrizeSnapshot (JSON)
  status        String   @default("pending_staff_approval")
  isAnonymous   Boolean  @default(false)
  playerEmail   String?
  playerName    String?
  playerPhone   String?
  submittedAt   DateTime @default(now())
  reviewedAt    DateTime?
  reviewedBy    String?
  reviewerRole  String?
  approvalNote  String?
  denialReason  String?
  redemptionNote String?
  redeemedAt    DateTime?
  redeemedBy    String?

  ticket     Ticket @relation(fields: [ticketId], references: [id])
  player     AppUser? @relation(fields: [playerId], references: [id])
  redemption Redemption?

  @@index([venueId, status])
  @@index([playerId])
  @@map("claims")
}

model Redemption {
  id          String   @id @default(cuid())
  ticketId    String
  claimId     String   @unique
  playerId    String?
  venueId     String
  prizeAmount Int
  redeemedBy  String
  redeemedAt  DateTime @default(now())
  notes       String?

  claim       Claim    @relation(fields: [claimId], references: [id])

  @@map("redemptions")
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  actorRole   String
  actionType  String
  targetType  String
  targetId    String
  venueId     String?
  details     String   @default("{}")
  createdAt   DateTime @default(now())

  actor       AppUser  @relation("AuditActor", fields: [actorUserId], references: [id])

  @@index([targetType, targetId])
  @@index([actorUserId])
  @@index([createdAt])
  @@map("audit_logs")
}

model FraudEvent {
  id        String   @id @default(cuid())
  ticketId  String
  playerId  String
  venueId   String?
  signal    String
  details   String   @default("{}")
  createdAt DateTime @default(now())

  ticket    Ticket   @relation(fields: [ticketId], references: [id])

  @@index([ticketId])
  @@map("fraud_events")
}

model RiskScore {
  id                   String   @id // same as ticketId
  ticketId             String   @unique
  playerId             String
  venueId              String?
  score                Int      @default(0)
  severity             String   @default("low")
  requiresManualReview Boolean  @default(false)
  status               String   @default("open")
  lastEventAt          DateTime @default(now())
  resolutionCode       String?
  resolutionNote       String?
  resolvedBy           String?
  resolvedAt           DateTime?

  ticket               Ticket   @relation(fields: [ticketId], references: [id])

  @@map("risk_scores")
}

model SettlementLog {
  id           String   @id @default(cuid())
  ticketId     String
  claimId      String
  venueId      String
  prizeAmount  Int
  finalAmount  Int
  settledAt    DateTime @default(now())
  settledBy    String

  @@map("settlement_logs")
}

model PayoutBatch {
  id          String   @id @default(cuid())
  venueId     String?
  status      String   @default("pending")
  totalAmount Int      @default(0)
  itemCount   Int      @default(0)
  createdBy   String
  createdAt   DateTime @default(now())
  processedAt DateTime?

  @@map("payout_batches")
}

model Reconciliation {
  id                String   @id @default(cuid())
  batchId           String
  venueId           String?
  periodStart       DateTime
  periodEnd         DateTime
  totalIssued       Int      @default(0)
  totalFinalized    Int      @default(0)
  totalApproved     Int      @default(0)
  totalRedeemed     Int      @default(0)
  totalPrizeAmount  Int      @default(0)
  generatedBy       String
  generatedAt       DateTime @default(now())

  @@map("reconciliations")
}

model StorageExport {
  id              String   @id @default(cuid())
  batchId         String
  venueId         String?
  fileName        String
  storagePath     String
  status          String   @default("generating")
  generatedBy     String
  generatedAt     DateTime @default(now())
  downloadedCount Int      @default(0)

  @@map("storage_exports")
}

model SignedDownload {
  id          String   @id @default(cuid())
  artifactId  String
  downloadUrl String
  expiresAt   DateTime
  requestedBy String
  requestedAt DateTime @default(now())

  @@map("signed_downloads")
}

model CardDesign {
  id                      String   @id @default(cuid())
  orgId                   String
  campaignId              String?
  name                    String
  design                  String   @default("{}") // all design fields (JSON)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@unique([orgId, campaignId])
  @@map("card_designs")
}

model WebhookEndpoint {
  id                  String   @id @default(cuid())
  orgId               String
  url                 String
  description         String?
  events              String   @default("[]") // webhook event types (JSON array)
  isActive            Boolean  @default(true)
  secret              String   // encrypted webhook signing secret
  consecutiveFailures Int      @default(0)
  lastDeliveryAt      DateTime?
  lastDeliveryStatus  String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  org        Organization @relation(fields: [orgId], references: [id])
  deliveries WebhookDelivery[]

  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id            String   @id @default(cuid())
  endpointId    String
  orgId         String
  event         String
  statusCode    Int?
  success       Boolean  @default(false)
  attemptCount  Int      @default(0)
  lastAttemptAt DateTime @default(now())
  createdAt     DateTime @default(now())

  endpoint      WebhookEndpoint @relation(fields: [endpointId], references: [id])

  @@map("webhook_deliveries")
}

model ApiKey {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  keyPrefix String
  keyHash   String
  scopes    String   @default("[]") // ApiKeyScope values (JSON array)
  isActive  Boolean  @default(true)
  lastUsedAt DateTime?
  createdBy String
  createdAt DateTime @default(now())
  expiresAt DateTime?
  revokedAt DateTime?
  revokedBy String?

  org       Organization @relation(fields: [orgId], references: [id])

  @@map("api_keys")
}

model ReferralCode {
  id                String   @id @default(cuid())
  orgId             String
  code              String   @unique
  creditAmountCents Int      @default(0)
  usageCount        Int      @default(0)
  maxUsages         Int?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())

  org         Organization @relation(fields: [orgId], references: [id])
  conversions ReferralConversion[]

  @@map("referral_codes")
}

model ReferralConversion {
  id                String   @id @default(cuid())
  referralCodeId    String
  referringOrgId    String
  convertedOrgId    String
  creditAppliedCents Int     @default(0)
  convertedAt       DateTime @default(now())

  referralCode      ReferralCode @relation(fields: [referralCodeId], references: [id])

  @@map("referral_conversions")
}

model CustomDomain {
  id          String   @id @default(cuid())
  orgId       String
  hostname    String   @unique
  verified    Boolean  @default(false)
  txtRecord   String?
  verifiedAt  DateTime?
  createdAt   DateTime @default(now())

  @@map("custom_domains")
}

model AnalyticsSummary {
  id               String   @id // campaignId
  campaignId       String   @unique
  orgId            String
  totalIssued      Int      @default(0)
  totalFinalized   Int      @default(0)
  totalClaimed     Int      @default(0)
  totalRedeemed    Int      @default(0)
  totalPrizeCents  Int      @default(0)
  uniquePlayers    Int      @default(0)
  conversionRate   Float    @default(0)
  claimRate        Float    @default(0)
  redemptionRate   Float    @default(0)
  topHands         String   @default("[]")
  dailyBreakdown   String   @default("[]")
  updatedAt        DateTime @updatedAt

  @@map("analytics_summaries")
}

model RateLimitBucket {
  id         String   @id // composite key string
  uid        String
  windowHour Int
  count      Int      @default(0)
  expiresAt  DateTime

  @@index([uid, windowHour])
  @@map("rate_limit_buckets")
}

model IdempotencyKey {
  id          String   @id // operation key
  processedAt DateTime @default(now())

  @@map("idempotency_keys")
}
