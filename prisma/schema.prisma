generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Better Auth tables ──────────────────────────────────────
// These are managed by Better Auth's Prisma adapter.

model user {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      session[]
  accounts      account[]
}

model session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model account {
  id                String  @id @default(cuid())
  userId            String
  accountId         String
  providerId        String
  accessToken       String?
  refreshToken      String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope             String?
  idToken           String?
  password          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              user     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ── Application tables ──────────────────────────────────────

model AppUser {
  id          String   @id @default(cuid())
  authId      String   @unique // links to user.id (Better Auth)
  email       String   @unique
  displayName String
  role        String   @default("player") // player, staff, admin, finance, super_admin
  venueIds    String   @default("[]")
  isActive    Boolean  @default(true)
  orgId       String?
  orgRole     String?
  orgName     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastLoginAt DateTime?

  tickets     Ticket[]
  claims      Claim[]
  auditLogs   AuditLog[]   @relation("AuditActor")

  @@map("app_users")
}

model Organization {
  id                     String   @id @default(cuid())
  name                   String
  slug                   String   @unique
  ownerId                String   // AppUser.id
  logoUrl                String?
  primaryColor           String?
  isActive               Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  // Subscription
  subscriptionTier       String   @default("starter")
  subscriptionStatus     String   @default("active")
  stripeCustomerId       String?
  stripeSubscriptionId   String?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?

  // Usage
  ticketsIssuedThisMonth Int      @default(0)
  ticketsResetAt         DateTime?
  overageTickets         Int      @default(0)
  overageAmountCents     Int      @default(0)

  members     OrgMember[]
  invites     OrgInvite[]
  campaigns   Campaign[]
  venues      Venue[]      @relation("OrgVenues")
  apiKeys     ApiKey[]
  webhookEndpoints WebhookEndpoint[]
  referralCodes    ReferralCode[]

  @@map("organizations")
}

model OrgMember {
  id          String   @id @default(cuid())
  orgId       String
  userId      String
  email       String
  displayName String
  role        String   @default("staff") // owner, admin, staff, viewer
  joinedAt    DateTime @default(now())
  invitedBy   String?

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@map("org_members")
}

model OrgInvite {
  id          String   @id @default(cuid())
  orgId       String
  orgName     String
  inviteeEmail String
  role        String   @default("staff")
  token       String   @unique @default(cuid())
  invitedBy   String
  createdAt   DateTime @default(now())
  expiresAt   DateTime
  acceptedAt  DateTime?
  acceptedBy  String?
  status      String   @default("pending") // pending, accepted, expired, revoked

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("org_invites")
}

model Onboarding {
  id             String   @id // orgId
  completedSteps String   @default("[]")
  currentStep    String   @default("org_created")
  completedAt    DateTime?

  @@map("onboarding")
}

model Venue {
  id        String   @id @default(cuid())
  orgId     String?
  name      String
  address   String   @default("")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  org       Organization? @relation("OrgVenues", fields: [orgId], references: [id])
  tickets   Ticket[]
  campaigns Campaign[]

  @@map("venues")
}

model Campaign {
  id               String    @id @default(cuid())
  orgId            String?
  venueId          String
  name             String
  description      String?
  oddsProfileId    String
  gameType         String    @default("poker")
  isActive         Boolean   @default(true)
  ticketPrice      Int       @default(0)
  startDate        DateTime?
  endDate          DateTime?
  guidelines       String?
  guidelinesRequired Boolean @default(false)
  allowAnonymous   Boolean   @default(false)
  totalTicketsLimit Int?
  createdAt        DateTime  @default(now())
  createdBy        String

  org          Organization? @relation(fields: [orgId], references: [id])
  venue        Venue         @relation(fields: [venueId], references: [id])
  oddsProfile  OddsProfile   @relation(fields: [oddsProfileId], references: [id])
  tickets      Ticket[]

  @@map("campaigns")
}

model OddsProfile {
  id           String   @id @default(cuid())
  orgId        String?
  name         String
  prizes       String   @default("[]") // Array of { handRank/tierName, prizeLabel, prizeAmount, isEnabled } (JSON)
  scratchLimit Int      @default(7)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  campaigns    Campaign[]

  @@map("odds_profiles")
}

model Ticket {
  id              String   @id @default(cuid())
  playerId        String?
  venueId         String
  campaignId      String
  orgId           String?
  deck            String   @default("[]") // string[] — shuffled card/item IDs (JSON)
  revealedCardIds String   @default("[]") // string[]
  scratchLimit    Int      @default(7)
  gameType        String   @default("poker")
  status          String   @default("issued")
  isFrozen        Boolean  @default(false)
  freezeReason    String?
  frozenAt        DateTime?
  frozenBy        String?
  claimCodeHash   String?
  claimCodeEmailSentAt DateTime?
  prizeSnapshot   String?  // PrizeSnapshot (JSON string)
  bestHandAtScratch Json?  // PrizeSnapshot
  allowAnonymous  Boolean  @default(false)
  distributionBatch Boolean @default(false)
  distributionBatchId String? // groups tickets from the same issue-batch
  lockedIp        String?  // first visitor's IP, locks ticket to them
  onePerIp        Boolean  @default(false) // if true, IP can only use 1 ticket per batch
  issuedBy        String?
  anonymousPlayer String?  // { email, name, phone } (JSON string)

  payoutOverride      Int?
  payoutOverrideNote  String?
  payoutOverrideBy    String?
  payoutOverrideRole  String?
  payoutOverrideAt    DateTime?

  createdAt       DateTime @default(now())
  finalizedAt     DateTime?
  claimSubmittedAt DateTime?
  approvedAt      DateTime?
  redeemedAt      DateTime?

  player   AppUser? @relation(fields: [playerId], references: [id])
  venue    Venue    @relation(fields: [venueId], references: [id])
  campaign Campaign @relation(fields: [campaignId], references: [id])
  claim    Claim?
  riskScore RiskScore?
  fraudEvents FraudEvent[]

  @@index([playerId, status])
  @@index([campaignId])
  @@index([venueId, status])
  @@map("tickets")
}

model Claim {
  id            String   @id // same as ticketId for deterministic dedup
  ticketId      String   @unique
  playerId      String?
  venueId       String
  campaignId    String
  orgId         String?
  prizeSnapshot String   @default("{}") // PrizeSnapshot (JSON)
  status        String   @default("pending_staff_approval")
  isAnonymous   Boolean  @default(false)
  playerEmail   String?
  playerName    String?
  playerPhone   String?
  shippingAddress String? // JSON: { street, city, state, zip, country }
  submittedAt   DateTime @default(now())
  reviewedAt    DateTime?
  reviewedBy    String?
  reviewerRole  String?
  approvalNote  String?
  denialReason  String?
  redemptionNote String?
  redeemedAt    DateTime?
  redeemedBy    String?

  ticket     Ticket @relation(fields: [ticketId], references: [id])
  player     AppUser? @relation(fields: [playerId], references: [id])
  redemption Redemption?

  @@index([venueId, status])
  @@index([playerId])
  @@map("claims")
}

model Redemption {
  id          String   @id @default(cuid())
  ticketId    String
  claimId     String   @unique
  playerId    String?
  venueId     String
  prizeAmount Int
  redeemedBy  String
  redeemedAt  DateTime @default(now())
  notes       String?

  claim       Claim    @relation(fields: [claimId], references: [id])

  @@map("redemptions")
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  actorRole   String
  actionType  String
  targetType  String
  targetId    String
  venueId     String?
  details     String   @default("{}")
  createdAt   DateTime @default(now())

  actor       AppUser  @relation("AuditActor", fields: [actorUserId], references: [id])

  @@index([targetType, targetId])
  @@index([actorUserId])
  @@index([createdAt])
  @@map("audit_logs")
}

model FraudEvent {
  id        String   @id @default(cuid())
  ticketId  String
  playerId  String
  venueId   String?
  signal    String
  details   String   @default("{}")
  createdAt DateTime @default(now())

  ticket    Ticket   @relation(fields: [ticketId], references: [id])

  @@index([ticketId])
  @@map("fraud_events")
}

model RiskScore {
  id                   String   @id // same as ticketId
  ticketId             String   @unique
  playerId             String
  venueId              String?
  score                Int      @default(0)
  severity             String   @default("low")
  requiresManualReview Boolean  @default(false)
  status               String   @default("open")
  lastEventAt          DateTime @default(now())
  resolutionCode       String?
  resolutionNote       String?
  resolvedBy           String?
  resolvedAt           DateTime?

  ticket               Ticket   @relation(fields: [ticketId], references: [id])

  @@map("risk_scores")
}

model SettlementLog {
  id           String   @id @default(cuid())
  ticketId     String
  claimId      String
  venueId      String
  prizeAmount  Int
  finalAmount  Int
  settledAt    DateTime @default(now())
  settledBy    String

  @@map("settlement_logs")
}

model PayoutBatch {
  id          String   @id @default(cuid())
  venueId     String?
  status      String   @default("pending")
  totalAmount Int      @default(0)
  itemCount   Int      @default(0)
  createdBy   String
  createdAt   DateTime @default(now())
  processedAt DateTime?

  @@map("payout_batches")
}

model Reconciliation {
  id                String   @id @default(cuid())
  batchId           String
  venueId           String?
  periodStart       DateTime
  periodEnd         DateTime
  totalIssued       Int      @default(0)
  totalFinalized    Int      @default(0)
  totalApproved     Int      @default(0)
  totalRedeemed     Int      @default(0)
  totalPrizeAmount  Int      @default(0)
  generatedBy       String
  generatedAt       DateTime @default(now())

  @@map("reconciliations")
}

model StorageExport {
  id              String   @id @default(cuid())
  batchId         String
  venueId         String?
  fileName        String
  storagePath     String
  status          String   @default("generating")
  generatedBy     String
  generatedAt     DateTime @default(now())
  downloadedCount Int      @default(0)

  @@map("storage_exports")
}

model SignedDownload {
  id          String   @id @default(cuid())
  artifactId  String
  downloadUrl String
  expiresAt   DateTime
  requestedBy String
  requestedAt DateTime @default(now())

  @@map("signed_downloads")
}

model CardDesign {
  id                      String   @id @default(cuid())
  orgId                   String
  campaignId              String?
  name                    String
  design                  String   @default("{}") // all design fields (JSON)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@unique([orgId, campaignId])
  @@map("card_designs")
}

model WebhookEndpoint {
  id                  String   @id @default(cuid())
  orgId               String
  url                 String
  description         String?
  events              String   @default("[]") // webhook event types (JSON array)
  isActive            Boolean  @default(true)
  secret              String   // encrypted webhook signing secret
  consecutiveFailures Int      @default(0)
  lastDeliveryAt      DateTime?
  lastDeliveryStatus  String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  org        Organization @relation(fields: [orgId], references: [id])
  deliveries WebhookDelivery[]

  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id            String   @id @default(cuid())
  endpointId    String
  orgId         String
  event         String
  statusCode    Int?
  success       Boolean  @default(false)
  attemptCount  Int      @default(0)
  lastAttemptAt DateTime @default(now())
  createdAt     DateTime @default(now())

  endpoint      WebhookEndpoint @relation(fields: [endpointId], references: [id])

  @@map("webhook_deliveries")
}

model ApiKey {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  keyPrefix String
  keyHash   String
  scopes    String   @default("[]") // ApiKeyScope values (JSON array)
  isActive  Boolean  @default(true)
  lastUsedAt DateTime?
  createdBy String
  createdAt DateTime @default(now())
  expiresAt DateTime?
  revokedAt DateTime?
  revokedBy String?

  org       Organization @relation(fields: [orgId], references: [id])

  @@map("api_keys")
}

model ReferralCode {
  id                String   @id @default(cuid())
  orgId             String
  code              String   @unique
  creditAmountCents Int      @default(0)
  usageCount        Int      @default(0)
  maxUsages         Int?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())

  org         Organization @relation(fields: [orgId], references: [id])
  conversions ReferralConversion[]

  @@map("referral_codes")
}

model ReferralConversion {
  id                String   @id @default(cuid())
  referralCodeId    String
  referringOrgId    String
  convertedOrgId    String
  creditAppliedCents Int     @default(0)
  convertedAt       DateTime @default(now())

  referralCode      ReferralCode @relation(fields: [referralCodeId], references: [id])

  @@map("referral_conversions")
}

model CustomDomain {
  id          String   @id @default(cuid())
  orgId       String
  hostname    String   @unique
  verified    Boolean  @default(false)
  txtRecord   String?
  verifiedAt  DateTime?
  createdAt   DateTime @default(now())

  @@map("custom_domains")
}

model AnalyticsSummary {
  id               String   @id // campaignId
  campaignId       String   @unique
  orgId            String
  totalIssued      Int      @default(0)
  totalFinalized   Int      @default(0)
  totalClaimed     Int      @default(0)
  totalRedeemed    Int      @default(0)
  totalPrizeCents  Int      @default(0)
  uniquePlayers    Int      @default(0)
  conversionRate   Float    @default(0)
  claimRate        Float    @default(0)
  redemptionRate   Float    @default(0)
  topHands         String   @default("[]")
  dailyBreakdown   String   @default("[]")
  updatedAt        DateTime @updatedAt

  @@map("analytics_summaries")
}

model DistributionBatch {
  id            String    @id @default(cuid())
  campaignId    String
  venueId       String
  orgId         String?
  name          String
  quantity      Int
  onePerIp      Boolean   @default(false)
  activatesAt   DateTime?
  expiresAt     DateTime?
  scheduledFor  DateTime?
  issuedBy      String
  issuedAt      DateTime  @default(now())
  voidedAt      DateTime?
  voidedBy      String?
  status        String    @default("active") // active, voided, expired, scheduled
  notes         String?
  tags          String    @default("[]") // JSON array of tag strings
  archived      Boolean   @default(false)
  archivedAt    DateTime?

  @@index([campaignId])
  @@index([orgId, issuedAt])
  @@index([archived])
  @@map("distribution_batches")
}

model ShortUrl {
  id         String   @id // short code (6-char base62)
  targetUrl  String
  createdAt  DateTime @default(now())
  hitCount   Int      @default(0)

  @@index([targetUrl])
  @@map("short_urls")
}

model RecipientList {
  id          String   @id @default(cuid())
  orgId       String
  name        String
  description String?
  recipients  String   @default("[]") // JSON: [{ name, email, phone }]
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orgId])
  @@map("recipient_lists")
}

model DeliveryLog {
  id                String    @id @default(cuid())
  batchId           String
  ticketId          String
  channel           String    // "email" | "sms"
  recipientName     String?
  recipientContact  String    // email or phone
  recipientListId   String?   // optional reference to a saved list
  status            String    // queued, sent, delivered, failed, bounced, opened, scratched
  errorMessage      String?
  sentAt            DateTime?
  deliveredAt       DateTime?
  openedAt          DateTime?
  scratchedAt       DateTime?
  reminderSentAt    DateTime?
  createdAt         DateTime  @default(now())

  @@index([batchId])
  @@index([ticketId])
  @@index([recipientContact])
  @@index([status])
  @@map("delivery_logs")
}

model ScheduledDelivery {
  id            String   @id @default(cuid())
  batchId       String
  payload       String   // JSON: { recipients, channel, throttleRate, rendered }
  scheduledFor  DateTime
  status        String   @default("pending") // pending, running, done, cancelled
  createdBy     String
  createdAt     DateTime @default(now())
  cancelledAt   DateTime?

  @@index([status, scheduledFor])
  @@map("scheduled_deliveries")
}

model DistributionTemplate {
  id          String   @id @default(cuid())
  orgId       String
  name        String
  campaignId  String?
  venueId     String?
  quantity    Int      @default(10)
  onePerIp    Boolean  @default(false)
  createdBy   String
  createdAt   DateTime @default(now())

  @@index([orgId])
  @@map("distribution_templates")
}

model DrawingResult {
  id           String   @id @default(cuid())
  campaignId   String
  orgId        String?
  winnerClaimId String
  winnerName   String
  winnerEmail  String
  winnerHand   String
  winnerPrize  String
  placement    Int      @default(1) // 1st, 2nd, 3rd
  totalEntries Int      @default(0)
  allEntrants  String   @default("[]") // JSON array of { name, email, claimId }
  drawnBy      String   // user ID who pressed spin
  drawnAt      DateTime @default(now())
  note         String?

  @@index([campaignId, drawnAt])
  @@map("drawing_results")
}

model RateLimitBucket {
  id         String   @id // composite key string
  uid        String
  windowHour Int
  count      Int      @default(0)
  expiresAt  DateTime

  @@index([uid, windowHour])
  @@map("rate_limit_buckets")
}

model IdempotencyKey {
  id          String   @id // operation key
  processedAt DateTime @default(now())

  @@map("idempotency_keys")
}

// ── Distribution Phase 3 ────────────────────────────────────

model SuppressionEntry {
  id        String   @id @default(cuid())
  orgId     String
  channel   String   // email, sms
  value     String   // email or phone (lowercased)
  reason    String   // unsubscribe, bounce, complaint, manual
  createdAt DateTime @default(now())
  @@unique([orgId, channel, value])
  @@index([orgId])
  @@map("suppression_entries")
}

model UnsubscribeToken {
  id        String   @id @default(cuid()) // token
  orgId     String
  channel   String
  value     String
  createdAt DateTime @default(now())
  usedAt    DateTime?
  @@index([orgId])
  @@map("unsubscribe_tokens")
}

model BatchSchedule {
  id          String   @id @default(cuid())
  orgId       String
  batchId     String?
  campaignId  String
  venueId     String
  quantity    Int
  channel     String   // email, sms
  recipients  String   // JSON array
  templateSubject String?
  templateBody    String?
  smsBody         String?
  scheduledFor    DateTime
  status      String   @default("scheduled") // scheduled, processing, sent, failed, cancelled
  createdBy   String
  createdAt   DateTime @default(now())
  executedAt  DateTime?
  error       String?
  @@index([status, scheduledFor])
  @@map("batch_schedules")
}

model DripSequence {
  id            String   @id @default(cuid())
  batchId       String
  step          Int      // 1, 2, 3
  delayHours    Int      // 24, 72, 168
  channel       String
  subject       String?
  body          String
  status        String   @default("pending") // pending, sent, cancelled
  scheduledFor  DateTime
  createdAt     DateTime @default(now())
  @@index([status, scheduledFor])
  @@index([batchId])
  @@map("drip_sequences")
}

model BatchApproval {
  id           String   @id @default(cuid())
  orgId        String
  requestedBy  String
  campaignId   String
  venueId      String
  quantity     Int
  estimatedCostCents Int
  payload      String   // JSON of full issue request
  status       String   @default("pending") // pending, approved, rejected
  reviewedBy   String?
  reviewedAt   DateTime?
  rejectionReason String?
  createdAt    DateTime @default(now())
  @@index([orgId, status])
  @@map("batch_approvals")
}

model RevenueAttribution {
  id            String   @id @default(cuid())
  batchId       String
  ticketId      String
  claimId       String?
  payoutCents   Int      @default(0)
  recordedAt    DateTime @default(now())
  @@index([batchId])
  @@map("revenue_attribution")
}

model AbTestVariant {
  id        String   @id @default(cuid())
  batchId   String
  label     String   // A, B
  subject   String
  body      String?
  sent      Int      @default(0)
  opened    Int      @default(0)
  scratched Int      @default(0)
  isWinner  Boolean  @default(false)
  @@index([batchId])
  @@map("ab_test_variants")
}

model AgeGateRecord {
  id        String   @id @default(cuid())
  ticketId  String   @unique
  dob       String   // ISO date
  confirmed Boolean  @default(true)
  ip        String?
  createdAt DateTime @default(now())
  @@map("age_gate_records")
}

model OrgGeoFence {
  id           String  @id @default(cuid())
  orgId        String  @unique
  blockedCodes String  @default("[]") // JSON array of country/region codes
  mode         String  @default("block") // block or allow
  @@map("org_geofences")
}

model GeoEvent {
  id        String   @id @default(cuid())
  ticketId  String
  batchId   String?
  ip        String
  country   String?
  region    String?
  city      String?
  createdAt DateTime @default(now())
  @@index([batchId])
  @@map("geo_events")
}

model RetentionPolicy {
  id        String   @id @default(cuid())
  orgId     String   @unique
  ttlDays   Int      @default(365)
  updatedAt DateTime @updatedAt
  @@map("retention_policies")
}

model EmbedToken {
  id        String   @id @default(cuid())
  orgId     String
  campaignId String
  domain    String?
  createdAt DateTime @default(now())
  hits      Int      @default(0)
  @@index([orgId])
  @@map("embed_tokens")
}
